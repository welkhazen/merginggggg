# --- Required ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SESSION_SECRET=

# --- PostHog (optional) ---
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Private Query API for the Analytics tab (personal API key + numeric project id)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# --- Crash alert emails via Resend (optional) ---
RESEND_API_KEY=
CRASH_ALERT_FROM=
CRASH_ALERT_TO=
CRASH_ALERT_APP_NAME=raW

# --- Vercel API for the System tab (optional) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# --- Supabase Management API for the System tab (optional) ---
SUPABASE_MGMT_TOKEN=
SUPABASE_PROJECT_REF=

# --- Push notifications to the user app (optional) ---
# Used to notify a user when their token request is approved/rejected. Point
# USER_APP_URL at the user app and set PUSH_SEND_SECRET to the same value as the
# user app's PUSH_SEND_SECRET. If unset, outcome pushes are skipped (the in-app
# bell in the user app still works).
USER_APP_URL=https://www.myraw.app
PUSH_SEND_SECRET=

# --- OpenAI (optional, server-side only) ---
# Never expose this as VITE_*. Store it only in server/host secrets.
OPENAI_API_KEY=
